blockid: one
display: def maxindex(arg):
indent: 0

blockid: two
display: ans = 0
indent: 1

blockid: three
display: for i in range(len(arg)):
indent: 1

blockid: four
display: if arg[i] > arg[ans]:
indent: 2

blockid: five
display: ans = i
indent: 3

blockid: six
display: return ans
indent: 1
