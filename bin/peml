#!/usr/bin/env ruby

lib = File.expand_path("../../lib", __FILE__)
$LOAD_PATH.unshift(lib) unless $LOAD_PATH.include?(lib)

require 'optparse'
require 'json'
require 'yaml'
require 'peml'

options = {
  format: :yaml,
  parse_opts: {}
}

OptionParser.new do |opts|
  opts.banner = "Usage: pemlparse [options] <filename>"

  Peml::TRANSFORMS.keys.each do |transform|
    opts.on("--#{transform.to_s.gsub('_', '-')}", "Enable #{transform} transform") do
      options[:parse_opts][transform] = true
    end
  end

  opts.on("--result-only", "Return only the parsed result") do
    options[:parse_opts][:result_only] = true
  end

  opts.on("--parse-descriptions", "Enable parsing of tags in test case descriptions") do
    options[:parse_opts][:render_tests_params] ||= {}
    options[:parse_opts][:render_tests_params].merge!({
      'parse_descriptions' => true,
      'pattern' => {
        'description' => '{% include "method_call" %} -> {% include "expected_template" %}',
        'description_annotation' => <<~DESCRIPTION_ANNOTATION
        {% show_yaml %}Description: {% include 'description' %}{% endshow_yaml %}
        DESCRIPTION_ANNOTATION
      },
      'java' => {
        'pattern' => {
          'description_annotation' => <<~JAVA_DESCRIPTION_ANNOTATION
          {% show_yaml %}@Description({% capture desc_out %}{% include 'description' %}{% endcapture %}{{ desc_out | string_literal }}){% endshow_yaml %}
          JAVA_DESCRIPTION_ANNOTATION
        }
      }
    })
  end

  opts.on("--file-name", "Include the name of the file being parsed on a line before the output") do
    options[:file_name] = true
  end

  opts.on("--check-only", "Return only diagnostic messages") do
    options[:check_only] = true
  end

  opts.on("--json", "Output in JSON format") do
    options[:format] = :json
  end

  opts.on("--yaml", "Output in YAML format (default)") do
    options[:format] = :yaml
  end

  opts.on("--expected FILENAME", "Compare output to expected YAML file") do |file|
    options[:expected] = file
  end

  opts.on("-o", "--output FILE", "Write result to FILE instead of stdout") do |file|
    options[:output] = file
  end

  opts.on("-h", "--help", "Prints this help") do
    puts opts
    exit
  end
end.parse!

if ARGV.empty?
  puts "Error: You must provide a filename."
  exit 1
end

filename = ARGV.first
options[:parse_opts][:filename] = filename

begin
  result = Peml.parse(options[:parse_opts])
  diagnostics = result['diagnostics'] || []
  
  if options[:check_only]
    if diagnostics.empty?
      exit 0
    else
      result = diagnostics
    end
  end
  expected_different = false
  if options[:expected]
    expected = YAML.safe_load(File.read(options[:expected]))
    # Normalize result for comparison (Dottie hashes or symbols might differ)
    # We'll use a simple comparison of YAML representations or deep merge check
    expected_different = (result != expected)
    if expected_different
      puts "Differences found in #{filename}:"
      # Using a simple way to show differences if they are not equal
      # We could use a more sophisticated diffing library but let's keep it simple for now
      require 'tempfile'
      actual_temp = Tempfile.new(['actual', '.yaml'])
      actual_temp.write(result.to_yaml)
      actual_temp.close
      system("diff -u #{options[:expected]} #{actual_temp.path}")
      actual_temp.unlink
    end
  else
    output = options[:format] == :json ? JSON.pretty_generate(result) : result.to_yaml
    if options[:output]
      File.write(options[:output], output)
    elsif !options[:expected]
      puts filename if options[:file_name]
      puts output
    end
  end
  if !diagnostics.empty? || expected_different
    exit 1
  end
rescue => e
  if defined?(Parslet::ParseFailed) && e.is_a?(Parslet::ParseFailed)
    STDERR.puts e.parse_failure_cause.ascii_tree
  else
    STDERR.puts "Error parsing file: #{e.message}"
    STDERR.puts e.backtrace
  end
  exit 1
end
